rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.isPremium == false;

      // Users can update their profile, but not isPremium
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPremium']);
    }

    // User exports
    match /users/{userId}/exports/{exportId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Stripe extension customer records
    match /customers/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /checkout_sessions/{id} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /subscriptions/{id} {
        allow read: if request.auth != null && request.auth.uid == uid;
      }

      match /payments/{id} {
        allow read: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
