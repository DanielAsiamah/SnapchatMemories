# Firebase Service Account Key (JSON file path)
# Download this from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_KEY_PATH="./serviceAccountKey.json"

# Firebase Project ID
FIREBASE_PROJECT_ID="snapvault-2cfe0"

# Firebase API Key (from Firebase Console > Project Settings > General > Your apps > Web app > SDK setup and configuration)
FIREBASE_API_KEY="your-firebase-api-key-here"

# Stripe Checkout Session URL for Premium Upgrade ($2.99)
# Create a Stripe Checkout Session and put the URL here
STRIPE_PREMIUM_CHECKOUT_URL="https://buy.stripe.com/test_..."
